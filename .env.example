# Prisma SQLite。`npx prisma migrate dev` でこのパスに dev.db が生成される。
DATABASE_URL="file:./prisma/dev.db"

# Cookie 署名用シークレット (16 文字以上)。本番では十分長いランダム値に差し替えること。
SESSION_SECRET="local-dev-secret-please-change-32chars-min"

# OpenCode パネル (RAG / Agentic 検索) で使う LLM バックエンド。
# 既定はローカル llama.cpp の OpenAI 互換 API。
# 別の OpenAI 互換エンドポイント (Vercel AI Gateway など) に差し替えるなら 3 つとも変更する。
LLAMA_BASE_URL="http://localhost:8080/v1"
LLAMA_MODEL="gemma"
LLAMA_API_KEY="not-needed"
